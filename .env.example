# Copy to apps/api/.env and fill in. Never commit .env.
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://mailmind:mailmind@localhost:5433/mailmind
REDIS_URL=redis://localhost:6379/0

# Google OAuth — console.cloud.google.com (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gemini — aistudio.google.com/apikey
GEMINI_API_KEY=

# Crypto — generate each:
#   SESSION_SECRET: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   FERNET_KEY:     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_SECRET=
FERNET_KEY=

# Sync
SYNC_DAYS=30

# Optional: LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=mailmind
